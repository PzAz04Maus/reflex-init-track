<form class="{{cssClass}}" autocomplete="off">
  <header class="sheet-header">
    <h1><input name="name" type="text" value="{{actor.name}}" /></h1>
  </header>

  <section class="sheet-body reflex-grid">
    <label>OODA</label>
    <input type="number" name="system.stats.ooda" value="{{system.stats.ooda}}" />

    <label>Speed</label>
    <input type="number" name="system.stats.speed" value="{{system.stats.speed}}" />

    <label>Awareness</label>
    <input type="number" name="system.stats.awareness" value="{{system.stats.awareness}}" />

    <label>Tick</label>
    <input type="number" name="system.combat.tick" value="{{system.combat.tick}}" />

    <label>Action Cost</label>
    <input type="number" name="system.combat.actionCost" value="{{system.combat.actionCost}}" />

    <label>Declared Action</label>
    <input type="text" name="system.combat.declaredAction" value="{{system.combat.declaredAction}}" />

    <label>Joined</label>
    <input type="checkbox" name="system.combat.joined" {{checked system.combat.joined}} />

    <label>HP</label>
    <div>
      <input type="number" name="system.resources.hp.value" value="{{system.resources.hp.value}}" /> /
      <input type="number" name="system.resources.hp.max" value="{{system.resources.hp.max}}" />
    </div>

    <label>Fatigue</label>
    <div>
      <input type="number" name="system.resources.fatigue.value" value="{{system.resources.fatigue.value}}" /> /
      <input type="number" name="system.resources.fatigue.max" value="{{system.resources.fatigue.max}}" />
    </div>
  </section>
</form>
