{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "build-tests",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["fvtt-types", "node"],
    "baseUrl": ".",
    "paths": {
      "reflex-core": ["../reflex-core/src/index.ts"],
      "reflex-core/*": ["../reflex-core/src/*"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"],
  "references": [
    { "path": "../reflex-core" }
  ]
}