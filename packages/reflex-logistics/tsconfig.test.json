{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "build-tests",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["fvtt-types", "node"],
    "baseUrl": ".",
    "paths": {
      "reflex-mechanics": ["../reflex-mechanics/src/index.ts"],
      "reflex-mechanics/*": ["../reflex-mechanics/src/*"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"],
  "references": [
    { "path": "../reflex-mechanics" }
  ]
}