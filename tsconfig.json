{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "lib": ["ES2022", "DOM"],
    "types": ["fvtt-types"],
    "rootDir": ".",
    "outDir": "build",
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "reflex-core": ["packages/reflex-core/src"],
      "reflex-core/*": ["packages/reflex-core/src/*"],
      "reflex-framework": ["packages/reflex-framework/src/index.ts"],
      "reflex-framework/*": ["packages/reflex-framework/src/*"],
      "reflex-system": ["packages/reflex-system/src/index.ts"],
      "reflex-system/*": ["packages/reflex-system/src/*"],
      "reflex-ui": ["packages/reflex-ui/src/index.ts"],
      "reflex-ui/*": ["packages/reflex-ui/src/*"],
      "reflex-mods": ["packages/reflex-mods/src/index.ts"],
      "reflex-mods/*": ["packages/reflex-mods/src/*"]
    },
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx"
  ]
}