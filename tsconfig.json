{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "lib": ["ES2022", "DOM"],
    "types": ["fvtt-types"],
    "rootDir": ".",
    "outDir": "output",
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "packages/*/src/**/*.ts"
  ]
}