{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "lib": ["ES2022", "DOM"],
    "types": ["fvtt-types"],
    "rootDir": ".",
    "outDir": "build",
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "paths": {
      "reflex-mechanics": ["./packages/reflex-mechanics/src"],
      "reflex-mechanics/*": ["./packages/reflex-mechanics/src/*"],
      "reflex-framework": ["./packages/reflex-framework/src/index.ts"],
      "reflex-framework/*": ["./packages/reflex-framework/src/*"],
      "foundry-system": ["./packages/foundry-system/src/index.ts"],
      "foundry-system/*": ["./packages/foundry-system/src/*"],
      "reflex-ui": ["./packages/reflex-ui/src/index.ts"],
      "reflex-ui/*": ["./packages/reflex-ui/src/*"],
      "reflex-mods": ["./packages/reflex-mods/src/index.ts"],
      "reflex-mods/*": ["./packages/reflex-mods/src/*"]
    },
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx"
  ],
  "exclude": [
    "packages/reflex-core/**"
  ]
}